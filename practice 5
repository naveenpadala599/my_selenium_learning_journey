from selenium import webdriver
from selenium.webdriver.common.by import By
from selenium.webdriver.common.keys import Keys
from selenium.webdriver.chrome.service import Service
from selenium.webdriver.support.ui import WebDriverWait
from selenium.webdriver.support import expected_conditions as EC
from selenium.webdriver.common.action_chains import ActionChains
from selenium.common.exceptions import NoSuchElementException, TimeoutException
import time
options=webdriver.ChromeOptions()
driver=webdriver.Chrome(options=options)
driver.maximize_window()
wait=WebDriverWait(driver, 10)
driver.get("https://www.wikipedia.org")
print(driver.title)
driver.refresh()
driver.back()
driver.forward()
search_box=driver.find_element(By.ID, "searchInput")
try:
    driver.find_element(By.NAME,"search")
    print("found by name")
except:
    print("name not found")
try:
    driver.find_element(By.CLASS_NAME, "central-featured")
    print("found by class name")
except:
    print("class name not found")
search_box_xpath=driver.find_element(By.XPATH, "//input[@id='searchInput']")
print("found by xpath")
try:
    driver.find_element(By.PARTIAL_LINK_TEXT, "English")
    print("found by partial link text")
except:
    print("link text not found")
search_box.send_keys("selenium software")
search_box.send_keys(Keys.ENTER)
try:
    heading=wait.until(EC.visibility_of_element_located((By.ID, "firstHeading")))
    print(heading.text)
    wait.until(EC.text_to_be_present_in_element((By.ID, "firstHeading"), "Selenium"))
    print("text verified")
except TimeoutException:
    print("element loading timed out")
try:
    clickable=wait.until(EC.element_to_be_clickable((By.XPATH, "//a")))
    clickable.click()
    print("clicked first link")
except:
    print("clickable element not found")
actions=ActionChains(driver)
links=driver.find_elements(By.TAG_NAME, "a")
if links:
    actions.move_to_element(links[5]).perform()
    print("hoverd over element")
driver.execute_script("window.scrollTo(0,1000)")
print("scrolled using js")
driver.execute_script("alert('Test Alert')")
try:
    alert=driver.switch_to.alert
    print(alert.text)
    alert.accept()
    print("alert accepted")
except:
    print("no alert found")
driver.switch_to.new_window("tab")
driver.get("https://www.python.org")
tabs=driver.window_handles
driver.switch_to.window(tabs[0])
print("swithced back to first tab")
driver.get("https://www.w3schools.com/html/tryit.asp?filename=tryhtml_iframe")
try:
    wait.until(EC.frame_to_be_available_and_switch_to_it((By.ID, "iframeresult")))
    print("switched to frame")
    driver.switch_to.default_content()
    print("switced back to main content")
except:
    print("frame not found")
upload=driver.find_element(By.XPATH, "//input[@type='file']")
upload.send_keys("c:/Path/to/file.txt")
cookies=driver.get_cookies()
print(len(cookies))
driver.add_cookie({"name":"demo", "value":"123"})
driver.save_screenshot("advanced_page.png")
print("screenshot saved")
html=driver.page_source
print(len(html))
try:
    driver.find_element(By.ID,"nonexistant")
except NoSuchElementException:
    print("handled missing elements")
driver.quit()    
